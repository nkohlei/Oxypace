{
    "name": "globalmessage-backend",
    "version": "1.0.2",
    "description": "Social media platform backend",
    "main": "server.js",
    "type": "module",
    "engines": {
        "node": "20.x"
    },
    "scripts": {
        "dev": "node --watch server.js",
        "start": "node server.js",
        "build": "cross-env CI=false NODE_OPTIONS=\"--max-old-space-size=4096\" npm install --prefix client --no-package-lock --legacy-peer-deps && cross-env CI=false NODE_OPTIONS=\"--max-old-space-size=4096\" npm run build --prefix client",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{js,jsx,json,md}\" --ignore-path .gitignore",
        "mobile:sync": "npm run build && npx cap sync",
        "mobile:assets": "npx capacitor-assets generate --android",
        "mobile:dev": "npx cap run android --live-reload --external",
        "mobile:open:android": "npx cap open android",
        "mobile:open:ios": "npx cap open ios"
    },
    "keywords": [
        "social-media",
        "messaging",
        "real-time"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.984.0",
        "@capacitor/android": "^8.2.0",
        "@capacitor/app": "^8.0.1",
        "@capacitor/camera": "^8.0.2",
        "@capacitor/filesystem": "^8.1.2",
        "@capacitor/keyboard": "^8.0.1",
        "@capacitor/push-notifications": "^8.0.2",
        "@capacitor/status-bar": "^8.0.1",
        "@socket.io/redis-adapter": "^8.3.0",
        "axios": "^1.13.4",
        "bcryptjs": "^2.4.3",
        "connect-mongo": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.2.1",
        "express-session": "^1.17.3",
        "express-validator": "^7.3.1",
        "form-data": "^4.0.5",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.2",
        "livekit-server-sdk": "^2.15.0",
        "mongoose": "^8.21.0",
        "multer": "^1.4.5-lts.1",
        "multer-s3": "^3.0.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.2",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "rss-parser": "^3.13.0",
        "sitemap": "^9.0.0",
        "socket.io": "^4.6.1"
    },
    "devDependencies": {
        "@capacitor/assets": "^3.0.5",
        "@capacitor/cli": "^8.2.0",
        "@capacitor/core": "^8.2.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.17.0",
        "eslint-plugin-security": "^3.0.1",
        "prettier": "^3.8.1"
    }
}
